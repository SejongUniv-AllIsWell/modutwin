# 원격 GPU 워커(DGX Spark) 전용 .env 예시
# docker-compose.gpu-remote.yml 과 함께 사용. 이 파일을 .env 로 복사해 채운다.
#
# ★ 비밀값(RABBITMQ/REDIS/MINIO/토큰)은 PC(웹서버)의 .env 와 반드시 동일해야 함.
#   PC 의 RabbitMQ/Redis/MinIO 에 인증하기 때문.

# PC(웹서버)의 접근 가능한 IP/호스트. Tailscale 등 사설망 IP 권장.
PC_HOST_IP=100.x.x.x

# 메시지 브로커 / 캐시 (PC 와 동일 값)
RABBITMQ_DEFAULT_USER=changeme
RABBITMQ_DEFAULT_PASS=changeme
REDIS_PASSWORD=changeme

# 오브젝트 스토리지 (PC 와 동일 값)
MINIO_ACCESS_KEY=changeme
MINIO_SECRET_KEY=changeme
MINIO_BUCKET=3dgs-platform

# 백엔드 콜백 (DGX 에서 PC 백엔드에 도달하는 주소).
# nginx 경유: http://${PC_HOST_IP}   /   백엔드 8000 직노출 시: http://${PC_HOST_IP}:8000
BACKEND_CALLBACK_URL=http://100.x.x.x
WORKER_CALLBACK_TOKEN=changeme
# notify_upload_progress(backend_callback.py)용. 보통 BACKEND_CALLBACK_URL 과 동일.
BACKEND_INTERNAL_URL=http://100.x.x.x
INTERNAL_API_TOKEN=

# door-ml(SAM3) 용 — facebook/sam3 gated 모델 접근 토큰 (HuggingFace).
# https://huggingface.co/facebook/sam3 에서 access request 후 발급.
HF_TOKEN=

# (선택) gsplat 경로/스텝 오버라이드 — 기본값이 /home/imlabdgx1/... 이라 DGX 면 생략 가능
# GSPLAT_PYTHON=/home/imlabdgx1/miniforge3/envs/gsplat/bin/python
# GSPLAT_TRAINER=/home/imlabdgx1/Development/gsplat/examples/simple_trainer.py
# GSPLAT_MAX_STEPS=7000

# (선택) SOG 변환 튜닝 — 기본 cpu/10 이면 그대로 둬도 됨
# SOG_DEVICE=cpu
# SOG_ITERATIONS=10
