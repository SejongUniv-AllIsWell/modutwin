# ============================================
# 3DGS Digital Twin Platform
# cp .env.example .env
# ============================================

# --- PostgreSQL ---
POSTGRES_USER=root
POSTGRES_PASSWORD=changeme
POSTGRES_DB=3dgs_platform

# --- PC Host IP (LAN IP of this PC — GPU worker connects to this address) ---
# Used to bind Redis/RabbitMQ/MinIO ports to this IP only (prevents public exposure)
# Find with: ip addr show | grep 'inet ' or hostname -I
PC_HOST_IP=127.0.0.1

# --- Redis ---
REDIS_PASSWORD=changeme

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=root
RABBITMQ_DEFAULT_PASS=changeme

# --- MinIO ---
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme123
MINIO_BUCKET=3dgs-platform
# For Frontend Presigned URL
MINIO_PUBLIC_ENDPOINT=localhost:9000 # your-domain.com
MINIO_PUBLIC_SECURE=false # true when endpoint is not localhost

# --- JWT ---
# generate secret key: openssl rand -hex 32
JWT_SECRET_KEY=generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256

# --- Google OAuth ---
# https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
KAKAO_REST_API_KEY=changeme

# --- Public URL(For OAuth redirect behind Nginx) ---
PUBLIC_BASE_URL=http://localhost # https://your-domain.com

# --- Extra CORS Origins (comma-separated, only applied when DEV_MODE=false) ---
# CORS_EXTRA_ORIGINS=http://192.168.0.51,http://10.0.0.1

# --- Dev Mode (true = pass Google OAuth / Only for Development Environment) ---
# Keep false outside isolated local development.
DEV_MODE=false

# --- Upload Limits ---
UPLOAD_MAX_FILE_SIZE_BYTES=21474836480
UPLOAD_SIZE_TOLERANCE_BYTES=1048576

# --- Feature Flags ---
# SAM3 dispatch is disabled until the sam3 worker and backend callback are implemented.
ENABLE_SAM3_DISPATCH=false

# --- Frontend ---
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_KAKAO_MAP_KEY=changeme

# --- Flower (Celery Monitoring, profiles: monitoring) ---
FLOWER_USER=admin
FLOWER_PASSWORD=changeme
